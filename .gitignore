# Exclude extracted folder (duplicates of root files)
extracted/

# Exclude original zip file
*.zip

# Exclude files with double extensions (originals)
*.png.png

# Exclude phonto (temp file)
phonto.PNG

# Local Netlify folder
.netlify

# Node deps (not used at runtime — Netlify serves static files)
node_modules/

# Local Claude Code settings
.claude/

# Local backups
*.splash-backup
*.bak
