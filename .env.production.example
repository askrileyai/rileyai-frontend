# Production Environment Variables for Railway Deployment
# Copy these to Railway Dashboard → Your Project → Variables

# ===== BACKEND API CONFIGURATION =====
# Replace with your Railway backend URL
NEXT_PUBLIC_API_URL=https://rileyai-backend-production.up.railway.app/api
NEXT_PUBLIC_WS_URL=wss://rileyai-backend-production.up.railway.app

# ===== APPLICATION URL =====
NEXT_PUBLIC_APP_URL=https://askrileyai.com

# ===== STRIPE CONFIGURATION =====
# Use your PRODUCTION Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_KEY_HERE

# Stripe Price IDs for each plan (from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID=price_YOUR_BASIC_PLAN_ID
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PLAN_ID
NEXT_PUBLIC_STRIPE_UNLIMITED_PRICE_ID=price_YOUR_UNLIMITED_PLAN_ID

# ===== PLAID CONFIGURATION =====
# Use your PRODUCTION Plaid Client ID
NEXT_PUBLIC_PLAID_CLIENT_ID=YOUR_PRODUCTION_PLAID_CLIENT_ID

# ===== CHROME EXTENSION =====
# Your published Chrome extension ID
NEXT_PUBLIC_EXTENSION_ID=YOUR_CHROME_EXTENSION_ID
NEXT_PUBLIC_EXTENSION_URL=https://chrome.google.com/webstore/detail/YOUR_EXTENSION_ID

# ===== FEATURE FLAGS =====
NEXT_PUBLIC_ENABLE_INVESTMENTS=true
NEXT_PUBLIC_ENABLE_TRADING_DESK=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ===== NOTES =====
# 1. DO NOT commit this file with real values to git
# 2. Set these in Railway Dashboard: Project → Variables tab
# 3. Railway will automatically rebuild when you change variables
# 4. Make sure your backend is deployed first and accessible
# 5. Test all integrations after deployment (Stripe, Plaid, etc.)
